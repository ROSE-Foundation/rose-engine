{
  // THROWAWAY typecheck-only project. Deliberately NOT part of the root tsconfig solution
  // (root references /prod packages only) and NOT a pnpm-workspace member — the regime
  // defense is that /prod never takes a dependency on /throwaway. This project may import
  // /prod source (allowed direction); `noEmit` relaxes the rootDir constraint so the
  // relative import into ../../../prod/packages/shared/src is permitted for typechecking.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts", "../../prod/packages/shared/src/money.ts"],
  "exclude": ["node_modules"]
}
