# rose-engine environment template. Copy to `.env` for local dev.
# NO real values or secrets in this file. The typed config loader (Story 1.3) refuses to
# start when a parked parameter is absent — it never defaults a correctness-critical value.
# Deployer / transfer-agent private keys are handled OUT-OF-BAND, never committed here.

# --- Database (PostgreSQL 18, local dev via docker-compose) ---
DATABASE_URL=

# --- Chain (Sepolia testnet in P0) ---
# The @rose/chain package (Story 5.1) refuses to start unless ALL of these are present and valid
# (NFR-4, refuse-if-absent). NO placeholder RPC URL or address is ever substituted. The deployed
# contract addresses are produced by `DeployRoseSuite.deploy(...)` (Story 4.6) and copied here by
# ops AFTER a real Sepolia deploy. Left blank intentionally.
SEPOLIA_RPC_URL=
ROSE_PAIR_ADDRESS=
ROSE_L_TOKEN_ADDRESS=
ROSE_S_TOKEN_ADDRESS=
ROSE_IDENTITY_REGISTRY_ADDRESS=

# --- Parked parameters (refuse-if-absent — Story 1.3 / §11.2). Left blank intentionally. ---
# NOTE_COUPON=
# USE_OF_PROCEEDS_SPLIT=
# CONVERSION_TO_PARTICIPATION=
# BACKING_FLOAT_FLOOR=
# MODEL_FLOOR_M=
# MODEL_FLOOR_G=
